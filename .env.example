# Copy to .env at the repo root and fill in. Never commit .env.

# --- apps/api ---
NODE_ENV=development
API_PORT=3001

# Supabase Postgres connection strings.
#   DATABASE_URL: pooled connection (port 6543), used at runtime.
#   DIRECT_URL:   unpooled connection (port 5432), used by `prisma migrate`.
# Grab both from Supabase → Project Settings → Database → Connection string.
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Shared secret for /internal/* routes (used by both api and conversation).
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=""

# OpenAI — used by the conversation worker (chat) AND the api (embeddings,
# memory extraction). Same key in both apps. Get one from platform.openai.com.
OPENAI_API_KEY=

# --- apps/conversation ---
CONVERSATION_PORT=3002

# Photon Spectrum (iMessage transport). Get these from the Photon dashboard.
PHOTON_PROJECT_ID=
PHOTON_PROJECT_SECRET=
PHOTON_LINE_NUMBER=

API_BASE_URL="http://localhost:3001"
CONVERSATION_BASE_URL="http://localhost:3002"

# --- apps/web ---
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"

# --- Inngest (Sprint 2: memory extraction + memory decay) ---
# In production set INNGEST_EVENT_KEY + INNGEST_SIGNING_KEY from the Inngest
# dashboard. Local dev: leave blank — Inngest CLI dev server handles it.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
