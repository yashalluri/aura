# Copy to .env and fill in. Never commit .env.

# --- apps/api ---
# Postgres connection string (local Docker or Neon/Supabase/Railway in prod).
DATABASE_URL="postgresql://aura:aura@localhost:5432/aura?schema=public"
API_PORT=3001

# --- apps/sms ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Base URL of the api app (used by the sms layer to call the backend).
API_BASE_URL="http://localhost:3001"
# LLM provider for the Aura chat persona. Pick one.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- apps/web ---
# Public URL where the api waitlist endpoint lives (if used).
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
