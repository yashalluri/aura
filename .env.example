# Copy to .env at the repo root and fill in. Never commit .env.

# --- apps/api ---
NODE_ENV=development
API_PORT=3001

# Supabase Postgres connection strings.
#   DATABASE_URL: pooled connection (port 6543), used at runtime.
#   DIRECT_URL:   unpooled connection (port 5432), used by `prisma migrate`.
# Grab both from Supabase → Project Settings → Database → Connection string.
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Shared secret for /internal/* routes. Generate with:
#   openssl rand -hex 32
INTERNAL_API_SECRET=""

# --- apps/sms (Phase 2) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
API_BASE_URL="http://localhost:3001"
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- apps/web (Phase 3) ---
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
