# Copy to .env at the repo root and fill in. Never commit .env.

# --- apps/api ---
NODE_ENV=development
API_PORT=3001

# Supabase Postgres connection strings.
#   DATABASE_URL: pooled connection (port 6543), used at runtime.
#   DIRECT_URL:   unpooled connection (port 5432), used by `prisma migrate`.
# Grab both from Supabase → Project Settings → Database → Connection string.
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Shared secret for /internal/* routes (used by both api and sms).
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=""

# --- apps/sms (Phase 2) ---
SMS_PORT=3002
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
API_BASE_URL="http://localhost:3001"
OPENAI_API_KEY=

# --- apps/web (Phase 3) ---
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"

# --- Phase 1: persistent memory + envelope encryption ---
# Master key for per-user encryption envelopes. Generate once with:
#   openssl rand -hex 32
# 32 bytes = 64 hex chars. Never rotate without a re-encryption migration.
KMS_ROOT_KEY=

# Inngest local dev mode — skips the cloud signing-key check.
# Set to 1 in dev. Leave blank in prod (then set INNGEST_SIGNING_KEY instead).
INNGEST_DEV=1
