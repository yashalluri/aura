generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String    @id @default(cuid())
  phoneNumber     String    @unique @map("phone_number")
  name            String?
  timezone        String    @default("UTC")
  checkInHour     Int       @default(8) @map("check_in_hour")
  toneMode        ToneMode  @default(neutral) @map("tone_mode")
  isOnboarded     Boolean   @default(false) @map("is_onboarded")
  mutedUntil      DateTime? @map("muted_until")
  quietHoursStart Int?      @map("quiet_hours_start")
  quietHoursEnd   Int?      @map("quiet_hours_end")
  encKey          String?   @map("enc_key")
  createdAt       DateTime  @default(now()) @map("created_at")

  contacts         Contact[]
  routines         Routine[]
  events           EventLog[]
  suggestions      DailySuggestionRow[]
  outboundMessages OutboundMessage[]
  messages         Message[]
  memories         Memory[]
  entities         Entity[]
  memoryAccesses   MemoryAccess[]
  integrations     IntegrationConnection[]
  signalEvents     SignalEvent[]

  @@map("users")
}

model Contact {
  id                  String           @id @default(cuid())
  userId              String           @map("user_id")
  name                String
  relationshipType    RelationshipType @default(friend) @map("relationship_type")
  targetFrequencyDays Int              @map("target_frequency_days")
  lastCheckInAt       DateTime?        @map("last_check_in_at")
  birthday            DateTime?
  createdAt           DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("contacts")
}

model Routine {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  name           String
  frequencyType  FrequencyType @map("frequency_type")
  frequencyValue Int           @map("frequency_value")
  lastDoneAt     DateTime?     @map("last_done_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("routines")
}

model EventLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
  @@map("event_logs")
}

model DailySuggestionRow {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  localDate String    @map("local_date")
  payload   Json
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, localDate])
  @@map("daily_suggestions")
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("waitlist")
}

model OutboundMessage {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  channel     String   // "imessage" | "voice"
  eventType   String   @map("event_type") // "daily_checkin" | "reach_out" | "routine_nudge" | "draft_prompt" | etc
  body        String
  sentAt      DateTime @default(now()) @map("sent_at")
  providerSid String?  @map("provider_sid")
  replyTo     String?  @map("reply_to")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
  @@map("outbound_messages")
}

enum RelationshipType {
  inner_circle
  friend
  acquaintance
  other
}

enum FrequencyType {
  daily
  weekly
  custom
}

enum ToneMode {
  neutral
  millennial
  gen_z
}

// ── Phase 1: persistent memory + knowledge graph ─────────────────────────────

enum MemoryKind {
  fact
  preference
  event
  relationship
  goal
  value
  pattern
}

enum EntityKind {
  person
  place
  project
  topic
  habit
  media
  org
}

model Message {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  role      String   // "user" | "assistant" | "system"
  content   String
  channel   String?  // "imessage" | "voice" | ...
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("messages")
}

model Memory {
  id             String     @id @default(cuid())
  userId         String     @map("user_id")
  kind           MemoryKind
  content        String     // encrypted at rest via User.encKey
  // embedding is pgvector(1536); accessed via raw SQL (see services/memory.ts)
  embedding      Unsupported("vector(1536)")?
  importance     Float      @default(0.5)
  confidence     Float      @default(0.7)
  source         String
  attrs          Json       @default("{}")
  createdAt      DateTime   @default(now()) @map("created_at")
  lastRecalledAt DateTime?  @map("last_recalled_at")
  decayedAt      DateTime?  @map("decayed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
  @@index([userId, importance(sort: Desc)])
  @@map("memories")
}

model Entity {
  id        String     @id @default(cuid())
  userId    String     @map("user_id")
  kind      EntityKind
  canonical String
  aliases   String[]   @default([])
  attrs     Json       @default("{}")
  embedding Unsupported("vector(1536)")?
  contactId String?    @unique @map("contact_id")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at")

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  relationsFrom  Relation[] @relation("RelationFrom")
  relationsTo    Relation[] @relation("RelationTo")

  @@index([userId, kind])
  @@map("entities")
}

model Relation {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  fromId      String    @map("from_id")
  toId        String    @map("to_id")
  kind        String
  strength    Float     @default(0.5)
  lastEventAt DateTime? @map("last_event_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  from Entity @relation("RelationFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   Entity @relation("RelationTo", fields: [toId], references: [id], onDelete: Cascade)

  @@index([userId, fromId])
  @@index([userId, toId])
  @@map("relations")
}

model MemoryAccess {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  memoryId   String   @map("memory_id")
  accessedAt DateTime @default(now()) @map("accessed_at")
  actor      String
  context    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, accessedAt(sort: Desc)])
  @@index([memoryId])
  @@map("memory_accesses")
}

// ── Phase 4: integrations + signals ─────────────────────────────────────────

model IntegrationConnection {
  id                   String    @id @default(cuid())
  userId               String    @map("user_id")
  app                  String    // "google_calendar" | "apple_health" | "icloud_mail" | ...
  status               String    @default("active") // active | revoked | error
  scopes               String[]  @default([])
  composioConnectionId String?   @map("composio_connection_id")
  webhookToken         String?   @unique @map("webhook_token")
  connectedAt          DateTime  @default(now()) @map("connected_at")
  lastSyncAt           DateTime? @map("last_sync_at")
  settings             Json      @default("{}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, app])
  @@map("integration_connections")
}

model SignalEvent {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  source     String   // "google_calendar" | "apple_health" | "apple_screen_time" | ...
  kind       String   // "calendar.event" | "health.sleep" | "screentime.session" | ...
  occurredAt DateTime @map("occurred_at")
  summary    String
  payload    Json     @default("{}")
  ingested   Boolean  @default(false)
  ingestErr  String?  @map("ingest_err")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt(sort: Desc)])
  @@index([userId, source])
  @@index([userId, ingested])
  @@map("signal_events")
}
