{
  "name": "aura",
  "version": "0.0.0",
  "private": true,
  "description": "Aura – the AI best friend + life assistant. Text-first, local-first.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api:dev": "npm run dev --workspace apps/api",
    "sms:dev": "npm run dev --workspace apps/sms",
    "web:dev": "npm run dev --workspace apps/web"
  },
  "engines": {
    "node": ">=20"
  }
}
